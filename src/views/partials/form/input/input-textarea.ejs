<div>
    <% if (textarea.label) { %>
        <label for="<%= textarea.id %>" class="block text-sm font-medium text-gray-700">
            <%= textarea.label %>
        </label>
    <% } %>
    <div class="mt-1">
        <textarea
            class="appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 h-100 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm <%= errors[textarea.name] ? 'border-red-300 text-red-900 placeholder-red-300 focus:ring-red-500 focus:border-red-500' : '' %>"
            <%=textarea.required ? "required" : "" %> name="<%= textarea.name %>" rows="3">
        <% if (!textarea.blockValue && (formData[textarea.name] || errors[textarea.name]?.value)) { %><%= formData[textarea.name] ? formData[textarea.name] : errors[textarea.name].value %><% } %>
        </textarea>
        <% if (errors[textarea.name]) { %>
            <% errors[textarea.name].rendered = true %>
            <p class="mt-2 text-sm text-red-600"><%= errors[textarea.name].msg %></p>
        <% } %>
    </div>
</div>