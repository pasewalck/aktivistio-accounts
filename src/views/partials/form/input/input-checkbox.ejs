<div>
    <% if (checkbox.label) { %>
        <label for="<%= checkbox.id %>" class="block text-sm font-medium text-gray-700">
            <%= checkbox.label %>
        </label>
    <% } %>
    <div class="mt-1">
        <div class="flex items-start">
            <div class="flex items-center h-5">
                <input class="focus:ring-indigo-500 h-4 w-4 text-indigo-600 border-gray-300 rounded"
                    <%=checkbox.required ? "required" : "" %>
                    type="checkbox"
                    name="<%= checkbox.name %>"
                    <% if (!checkbox.blockValue && (formData[checkbox.name] || errors[checkbox.name]?.value)) { %>checked<% } %>
                >
            </div>
            <div class="ml-3 text-sm">
                <label class="font-medium text-gray-700"><%= checkbox.msg %></label>
            </div>
        </div>
        <% if (errors[checkbox.name]) { %>
            <% errors[checkbox.name].rendered = true %>
            <p class="mt-2 text-sm text-red-600"><%= errors[checkbox.name].msg %></p>
        <% } %>
    </div>
</div>