<div class="max-w-7xl mx-auto">
    <div class="bg-white shadow sm:rounded-lg">
        <div class="px-4 py-5 sm:p-6">
            <h3 class="text-lg leading-6 font-medium text-gray-900">
                <%= __("page.account_2fa.title") %>
            </h3>
            <div class="mt-2 max-w-xl text-sm text-gray-500">
                <% if (has2fa) { %>
                    <p><%= __("page.account_2fa.enabled_message") %></p>
                <% } else { %>
                    <p><%= __("page.account_2fa.disabled_message") %></p>
                <% } %>
            </div>
            <div class="mt-5">
                <% if (has2fa) { %>
                    <form action="<%= urlUtils.extendUrl(baseUrl, 'account/2fa/remove').href %>" method="post">
                        <input type="hidden" value="<%= csrfToken %>" name="_csrf">
                        <button type="submit" class="inline-flex items-center justify-center px-4 py-2 border border-transparent font-medium rounded-md text-red-700 bg-red-100 hover:bg-red-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 sm:text-sm">
                            <%= __("page.account_2fa.remove_button") %>
                        </button>
                    </form>
                <% } else { %>
                    <a href="<%= urlUtils.extendUrl(baseUrl, 'account/2fa/add').href %>" class="inline-flex items-center justify-center px-4 py-2 border border-transparent font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:text-sm">
                        <%= __("page.account_2fa.setup_2fa") %>
                    </a>
                <% } %>
            </div>
        </div>
    </div>
</div>