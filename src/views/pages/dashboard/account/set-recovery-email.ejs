<div class="wrapper flex-container">
    <div class="container container-medium-width container-filled-background">

        <% if (hasRecoveryEmail) { %>
            <h2><%= __("page.account_recovery_update_email.title") %></h2>
        <% } else { %>
            <h2><%= __("page.account_recovery_add_email.title") %></h2>
        <% } %>

        <form class="form" autocomplete="off" action="" method="post">
            <input type="hidden" value="<%= csrfToken %>" name="_csrf">

            <fieldset>

                <%- include("../../../partials/alert-info.ejs",{info: __("page.account_recovery_set_email.waring_valid_email"),moreInfoLink: "https://0xacab.org/aktivistek/aktivistio-accounts/-/blob/master/documentation/SECURITY.md"}) %>

                <div class="form-group">
                    <label class="label"><%= __('common.current_password') %></label>
                    <%- include("../../../partials/form/input-field.ejs",{field: {name:"currentPassword",type:"password",required:true}}) %>
                </div>

                <div class="form-group">
                    <label class="label"><%= __('page.account_recovery_set_email.new_email') %></label>
                    <%- include("../../../partials/form/input-field.ejs",{field: {name:"email",type:"email",required:true}}) %>
                </div>

            </fieldset>

            <div class="form-action-group">
              <div class="button-group-row">
                <button type="submit" class="button primary"><%= __('page.account_recovery_set_email.set_new_button') %></button>
              </div>
            </div>

        </form>

    </div>
</div>