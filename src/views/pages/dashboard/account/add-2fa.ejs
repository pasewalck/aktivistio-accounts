<div class="wrapper flex-container">
    <div class="container container-medium-width container-filled-background">

        <h2><%= __("security.2fa.add_title") %></h2>

        <div class="qr-code-box">
            <img src="<%= qrCodeSrc %> " alt="">
            <div><%= secret %></div>
        </div>

        <form class="form" action="<%= urlUtils.extendUrl(baseUrl, 'account/2fa/set').href %>" method="post">
            <input type="hidden" value="<%= csrfToken %>" name="_csrf">
            <input type="hidden" name="secret" value="<%= secret %> ">

            <fieldset>

                <div class="form-group">
                    <label class="label"><%= __('widget.2fa.enter_code.label') %></label>
                    <%- include("../../../partials/form/input-field.ejs",{field: {name:"token",type:"text",required:true}}) %>
                </div>

            </fieldset>

            <div class="form-action-group">
                <button class="button primary"><%= __("common.setup") %> </button>
            </div>

        </form>

    </div>
</div>