<div class="max-w-7xl mx-auto space-y-6">
    <div class="bg-white shadow sm:rounded-lg">
        <div class="px-4 py-5 sm:p-6">
            <h3 class="text-lg leading-6 font-medium text-gray-900">
                <%= __("account.recovery.title") %>
            </h3>

             <div class="mt-2 max-w-xl text-sm text-gray-500">
                <% if (currentRecovery && (currentRecovery.token || currentRecovery.email)) { %>
                    <p><%= __("account.recovery.text.recovery_methods_count", (currentRecovery.token && currentRecovery.email) ? 2 : 1) %></p>
                <% } else { %>
                    <p><%= __("account.recovery.no_method_set_message") %></p>
                <% } %>
            </div>

            <% if (currentRecovery && (currentRecovery.token || currentRecovery.email)) { %>
                <ul class="mt-5 border-t border-gray-200 divide-y divide-gray-200">
                    <% if (currentRecovery.token) { %>
                        <li class="py-4 flex items-center justify-between">
                            <div class="flex flex-col">
                                <span class="text-sm font-medium text-gray-900"><%= __("account.recovery.active_list.label.token") %></span>
                            </div>
                            <div class="flex items-center space-x-4">
                                <a href="<%= urlUtils.extendUrl(baseUrl, 'account/recovery/set-token').href %>" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">
                                    <%= __("common.button.modify") %>
                                </a>
                                <a href="<%= urlUtils.extendUrl(baseUrl, 'account/recovery/delete-token').href %>" class="text-sm font-medium text-red-600 hover:text-red-500">
                                    <%= __("common.button.delete") %>
                                </a>
                            </div>
                        </li>
                    <% } %>
                    <% if (currentRecovery.email) { %>
                        <li class="py-4 flex items-center justify-between">
                             <div class="flex flex-col">
                                <span class="text-sm font-medium text-gray-900"><%= __("account.recovery.active_list.label.email") %></span>
                            </div>
                            <div class="flex items-center space-x-4">
                                <a href="<%= urlUtils.extendUrl(baseUrl, 'account/recovery/set-email').href %>" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">
                                    <%= __("common.button.modify") %>
                                </a>
                                <a href="<%= urlUtils.extendUrl(baseUrl, 'account/recovery/delete-email').href %>" class="text-sm font-medium text-red-600 hover:text-red-500">
                                    <%= __("common.button.delete") %>
                                </a>
                            </div>
                        </li>
                    <% } %>
                </ul>
            <% } %>

            <div class="mt-6 flex space-x-3">
                 <% if (!currentRecovery?.email) { %>
                    <a href="<%= urlUtils.extendUrl(baseUrl, 'account/recovery/set-email').href %>" class="inline-flex items-center justify-center px-4 py-2 border border-transparent font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:text-sm">
                        <%= __("account.recovery.add_email_button") %>
                    </a>
                <% } %>
                <% if (!currentRecovery?.token) { %>
                     <a href="<%= urlUtils.extendUrl(baseUrl, 'account/recovery/set-token').href %>" class="inline-flex items-center justify-center px-4 py-2 border border-transparent font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 sm:text-sm">
                        <%= __("account.recovery.add_token_button") %>
                    </a>
                <% } %>
            </div>
        </div>
    </div>
</div>