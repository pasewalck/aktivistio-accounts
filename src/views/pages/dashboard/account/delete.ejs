<div class="wrapper flex-container">
    <div class="container container-medium-width container-filled-background">
        <h2><%= __("page.own-account.delete.title") %></h2>

        <form class="form" action="" method="post">
            <fieldset>
                <%- include("../../../partials/alert-info.ejs",{info: __("page.own-account.delete.warninge.warning"),moreInfoLink:false}) %>

                <div class="form-group">
                    <label class="label"><%= __('common.password') %></label>
                    <%- include("../../../partials/form/input-field.ejs",{field: {name:"password",type:"password",required:true}}) %>
                </div>

                <div class="form-group">
                    <label class="label"><%= __('common.confirm') %></label>
                    <%- include("../../../partials/form/input-checkbox.ejs",{checkbox: {name:"confirm",msg:__('page.own-account.delete.checkbox.message')}}) %>
                </div>
            </fieldset>

            <input type="hidden" value="<%= csrfToken %>" name="_csrf">
            <div class="form-action-group">
                <button class="button red" type="submit"><%= __("page.own-account.delete.button.text") %></button>
            </div>
        </form>
    </div>
</div>