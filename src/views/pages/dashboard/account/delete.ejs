<div class="max-w-7xl mx-auto">
    <div class="bg-red-50 shadow sm:rounded-lg border border-red-200">
        <div class="px-4 py-5 sm:p-6">
            <h3 class="text-lg leading-6 font-medium text-red-800">
                <%= __("account.delete.confirm.title") %>
            </h3>

            <form class="mt-5 space-y-6 max-w-md" action="" method="post">
                 <input type="hidden" value="<%= csrfToken %>" name="_csrf">

                <%- include("../../../partials/alert-info.warn.ejs",{info: __("account.delete.confirm.alert.message"),moreInfoLink:false}) %>

                <%- include("../../../partials/form/input/input-field.ejs",{field: {label:__('common.password'),id:"password",name:"password",type:"password",required:true}}) %>

                <%- include("../../../partials/form/input/input-checkbox.ejs",{checkbox: {label:__('common.confirm'),id:"confirm",name:"confirm",msg:__('account.delete.confirm.checkbox.message')}}) %>

                <div>
                    <button type="submit" class="inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
                        <%= __("account.delete.confirm.button.text") %>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>