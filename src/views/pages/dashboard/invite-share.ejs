<div class="max-w-7xl mx-auto">
    <div class="bg-white shadow sm:rounded-lg">
        <div class="px-4 py-5 sm:p-6 flex flex-col items-center">
            <h3 class="text-lg leading-6 font-medium text-gray-900 mb-6">
                <%= __("auth.invite.share.title", app.name) %>
            </h3>
            
            <div class="bg-white p-4 border border-gray-200 rounded-lg shadow-sm">
                <img src="<%= inviteQR %>" alt="QR Code" class="h-64 w-64">
            </div>
            
            <div class="mt-4 p-3 bg-gray-50 rounded border border-gray-200 text-sm text-gray-500 break-all text-center max-w-lg">
                <%= inviteURL %>
            </div>
        </div>
    </div>
</div>