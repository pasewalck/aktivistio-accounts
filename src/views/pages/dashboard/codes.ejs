<% const canGenerate = hasPermission(account.role, Permission.MANAGE_OWN_INVITES); %>
<% const canManageSystemInvites = hasPermission(account.role, Permission.MANAGE_SYSTEM_INVITES); %>

<style>
    @media only screen and (min-width: 1000px) {
        .invite-code .invite-hidden-part {
            filter: blur(3px);
            transition: all 0.5s;
        }
    }
    .invite-code:hover .invite-hidden-part {
        filter: blur(0px);
    }
    @keyframes slide-in {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }
    .animate-in-invite {
        animation: slide-in 0.5s ease-in forwards;
    }
</style>

<div class="space-y-6">
    <% if (inviteCodes.length > 0 || !canGenerate) { %>
        <div class="bg-white shadow overflow-hidden sm:rounded-lg">
            <div class="px-4 py-5 sm:px-6">
                <h3 class="text-lg leading-6 font-medium text-gray-900">
                    <%= __("admin.invite.personal") %>
                </h3>
            </div>
            <% if (inviteCodes.length <= 0 && lockedInviteCodes.length > 0 && !canGenerate) { %>
                <div class="p-4">
                    <% var daysLeft = (new Date(lockedInviteCodes[0].createDate * 1000) - new Date().getTime()) / 1000 / (60 * 60 * 24); %>
                    <%- include("../../partials/alert-info.ejs", { info: __("admin.invite.invites_unlocked_message", Number.parseFloat(daysLeft).toFixed(0)), moreInfoLink: false }) %>
                </div>
            <% } else { %>
                <%- include("../../partials/invite-list.ejs", { inviteCodes: inviteCodes, canDelete: canGenerate, noInvitesMessage: 'admin.invite.no_invites_message', animateNewest: animateNewest }) %>
            <% } %>
        </div>
    <% } %>

    <% if (canManageSystemInvites && (systemInviteCodes.length > 0)) { %>
        <div class="bg-white shadow overflow-hidden sm:rounded-lg">
            <div class="px-4 py-5 sm:px-6">
                <h3 class="text-lg leading-6 font-medium text-gray-900">
                    <%= __("admin.invite.system") %>
                </h3>
            </div>
            <%- include("../../partials/invite-list.ejs", { inviteCodes: systemInviteCodes, canDelete: canManageSystemInvites, noInvitesMessage: 'admin.invite.no_system_invites_message', animateNewest: false }) %>
        </div>
    <% } %>

    <% if (canGenerate || canManageSystemInvites) { %>
        <div class="bg-white shadow sm:rounded-lg">
            <div class="px-4 py-5 sm:p-6">
                <h3 class="text-lg leading-6 font-medium text-gray-900">
                    <%= __("admin.invite.generate") %>
                </h3>
                <form class="mt-5 space-y-6" action="<%= urlUtils.extendUrl(baseUrl, 'invites/generate').href %>" method="post">
                    <input type="hidden" value="<%= csrfToken %>" name="_csrf">

                    <% if (canManageSystemInvites) { %>
                        <%- include("../../partials/form/input/input-select.ejs", {
                            errors: {},
                            formData: {},
                            select: {
                                label: __('admin.invite.mode'),
                                name: "inviteMode",
                                id: "inviteMode",
                                value: "private",
                                options: [
                                    { value: "private", displayName: __("admin.invite.mode_private") },
                                    { value: "system", displayName: __("admin.invite.mode_system") }
                                ],
                                info: __("admin.invite.mode_hint")
                            }
                        }) %>

                    <% } else { %>
                        <input type="hidden" name="inviteMode" value="private">
                    <% } %>

                    <%- include("../../partials/form/input/input-field.ejs", {
                        errors: {},
                        formData: {},
                        field: {
                            label: __('admin.invite.uses'),
                            name: "count",
                            id: "count",
                            type: "number",
                            required: true,
                            min: 1,
                            max: 1000,
                            value: 1,
                            info: __("admin.invite.uses_hint")
                        }
                    }) %>

                    <%- include("../../partials/form/input/input-field.ejs", {
                        errors: {},
                        formData: {},
                        field: {
                            label: __('admin.invite.expire_label'),
                            name: "date",
                            id: "date",
                            type: "date"
                        }
                    }) %>

                    <div>
                        <button type="submit" class="inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                            <%= __("admin.invite.generate_invite") %>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    <% } %>
</div>