<div class="sm:mx-auto sm:w-full sm:max-w-md">
    <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900">
        <%= __('auth.consent_page.title') %>
    </h2>
</div>

<div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
     <div class="bg-white shadow overflow-hidden sm:rounded-lg border border-gray-200 mb-6">
        <div class="px-4 py-5 sm:p-6 h-64 overflow-y-auto text-sm text-gray-500">
             <%- consents %>
        </div>
    </div>

    <form class="space-y-6" autocomplete="off" action="<%= urlUtils.extendUrl(baseUrl,isRegister ? `register` : `welcome/${formData.actionToken}`,`consent`).href %>" method="post">
        <input type="hidden" value="<%= csrfToken %>" name="_csrf">

        <%- include("../../../partials/form/input/input-checkbox.ejs",{checkbox: {name:"verify",msg:__('auth.consent_page.verification_statement')}}) %>

        <div>
            <button type="submit" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                <%= __('account.create') %>
            </button>
        </div>
    </form>
</div>