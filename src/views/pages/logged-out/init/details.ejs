<div class="sm:mx-auto sm:w-full sm:max-w-md">
    <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900">
        <%= __('auth.register.title') %>
    </h2>
</div>

<div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <form class="space-y-6" autocomplete="off" action="<%= urlUtils.extendUrl(baseUrl,isRegister ? `register` : `welcome/${formData.actionToken}`).href %>" method="post">
        <input type="hidden" value="<%= csrfToken %>" name="_csrf">

        <% if (isRegister) { %>
            <%- include("../../../partials/form/input/input-field.ejs",{
                field: {
                    label: __('common.invite_code'),id:"inviteCode", name:"inviteCode",type:"text",required:true,
                    help: {
                        link: urlUtils.extendUrl(baseUrl, 'invite-request').href,
                        displayName: __('auth.register.no_invite_code_question')
                    }
                }
            }) %>
        <% } %>

        <%- include("../../../partials/form/input/input-field.ejs",{field: {label:__('common.username'),name:"username",id:"username",type:"text",required:true}}) %>

        <%- include("../../../partials/form/input/input-field.ejs",{field: {label:__('common.password'),name:"password",id:"password",type:"password",required:true}}) %>

        <%- include("../../../partials/form/input/input-field.ejs",{field: {label: __('common.confirm_password'),name:"passwordConfirm",id:"passwordConfirm",type:"password",required:true}}) %>

        <%- include("../../../partials/form/input/input-select.ejs",{select: {label:__('common.select_recovery_method'), name:"recoveryMethod",id:"recoverySelect",options:[
                    {value:"email",displayName:__('common.recovery_email.title')},
                    {value:"token",displayName:__('common.recovery_token.title')}
                ],defaultNone:{msg:__('common.select_recovery_method')}}}) %>

        <div id="recoveryEmailSection">
            <%- include("../../../partials/alert-info.ejs",{info: __("common.recovery_email_secure_info"),moreInfoLink: "https://github.com/pasewalck/aktivistio-accounts/blob/main/documentation/SECURITY.md"}) %>
            <%- include("../../../partials/form/input/input-field.ejs",{field: {label:__('common.recovery_email_address'),name:"recoveryEmail",id:"recoveryEmail",type:"text"}}) %>
        </div>

        <div id="recoveryTokenSection">
            <input type="hidden" name="recoveryToken" value="<%= recoveryToken %>">
            <label class="block text-sm font-medium text-gray-700">
                <%= __('common.recovery_token.title') %>
            </label>
            <div class="mt-1 bg-gray-50 p-3 rounded border border-gray-200 font-mono text-sm break-all">
                <p><%= recoveryToken %></p>
            </div>
            <%- include("../../../partials/form/input/input-checkbox.ejs",{checkbox: {name:"recoveryTokenVerify",msg:__('common.recovery_token_written_confirm')}}) %>
        </div>

        <%- include("../../../partials/form/errors.ejs") %>

        <div>
            <button type="submit" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                <%= __('auth.register.submit_details') %>
            </button>
        </div>
    </form>
</div>

<script>
    const recoverySelect = document.getElementById("recoverySelect");

    function updateRecovery() {
        const selected = recoverySelect.value;
        const emailSection = document.getElementById('recoveryEmailSection');
        const tokenSection = document.getElementById('recoveryTokenSection');

        if (selected == "email") {
            emailSection.style.display = "";
            tokenSection.style.display = "none";
        } else if (selected == "token") {
            emailSection.style.display = "none";
            tokenSection.style.display = "";
        } else {
            emailSection.style.display = "none";
            tokenSection.style.display = "none";
        }
    }

    if (recoverySelect) {
        recoverySelect.addEventListener("change", updateRecovery);
        updateRecovery();
    }
</script>