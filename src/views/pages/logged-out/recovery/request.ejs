<div class="sm:mx-auto sm:w-full sm:max-w-md">
    <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900">
        <%= __('auth.recovery_request.title') %>
    </h2>
</div>

<div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <form class="space-y-6" autocomplete="off" action="<%= urlUtils.extendUrl(baseUrl,`account-recovery`,`request`).href %>" method="post">
        <input type="hidden" value="<%= csrfToken %>" name="_csrf">

        <%- include("../../../partials/form/input/input-field.ejs",{field: {label: __('common.username'),id:"username", name:"username",type:"text",required:true}}) %>

        <%- include("../../../partials/form/input/input-select.ejs",{select: {label:__('common.recovery_method.title'),name:"method",id:"recoverySelect",options:[
                    {value:"email",displayName:__('common.recovery_email.title')},
                    {value:"token",displayName:__('common.recovery_token.title')}
                ],defaultNone:{msg:__('common.select_recovery_method')}}}) %>

        <%- include("../../../partials/form/input/input-field.ejs",{field: {label: __('common.recovery_email.title'),name:"email",id:"email",groupId:"recoveryEmailSection",type:"email"}}) %>

        <%- include("../../../partials/form/input/input-field.ejs",{field: {label: __('common.recovery_token.title'),name:"token",id:"token",groupId:"recoveryTokenSection",type:"text"}}) %>

        <%- include("../../../partials/form/errors.ejs") %>

        <div>
            <button type="submit" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                <%= __('common.form.submit') %>
            </button>
             <p class="mt-2 text-center text-sm text-gray-600">
                <%= __('auth.recovery.no_methods_question') %>
                <a href="https://github.com/pasewalck/aktivistio-accounts/blob/main/documentation/SECURITY.md?ref_type=heads" class="font-medium text-indigo-600 hover:text-indigo-500">
                    <%= __('common.learn_more') %>
                </a>
            </p>
        </div>
    </form>
</div>

<script>
    const recoverySelect = document.getElementById("recoverySelect");

    function updateRecovery() {
        const selected = recoverySelect.value;
        const emailSection = document.getElementById('recoveryEmailSection');
        const tokenSection = document.getElementById('recoveryTokenSection');

        if (selected == "email") {
            emailSection.style.display = "";
            tokenSection.style.display = "none";
        } else if (selected == "token") {
            emailSection.style.display = "none";
            tokenSection.style.display = "";
        } else {
            emailSection.style.display = "none";
            tokenSection.style.display = "none";
        }
    }

    if (recoverySelect) {
        recoverySelect.addEventListener("change", updateRecovery);
        updateRecovery();
    }
</script>