<div class="sm:mx-auto sm:w-full sm:max-w-md">
    <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900">
        <%= title %>
    </h2>
    <p class="mt-2 text-center text-sm text-gray-600">
        <%= __('auth.consent.confirm_access', { clientId: clientId }) %>
    </p>
</div>

<div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <form class="space-y-6" autocomplete="off" action="<%= urls.action %>" method="post">
        <input type="hidden" value="<%= csrfToken %>" name="_csrf">

        <div>
            <button type="submit" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                <%= __('auth.consent.verify') %>
            </button>
            <% if (urls.abort) { %>
                <div class="mt-4">
                    <a href="<%= urls.abort %>" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
                        <%= __('auth.consent.abort') %>
                    </a>
                </div>
            <% } %>
        </div>
    </form>
</div>