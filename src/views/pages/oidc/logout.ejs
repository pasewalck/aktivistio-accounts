<div class="sm:mx-auto sm:w-full sm:max-w-md">
    <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900">
        <%= __("auth.logout.title") %>
    </h2>
    <p class="mt-2 text-center text-sm text-gray-600">
        <%= __("auth.logout.confirm_message") %>
    </p>
</div>

<div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <form class="space-y-6" autocomplete="off" action="<%= urlUtils.extendUrl(baseUrl, 'oidc/session/end/confirm/').href %>" method="post">
        <input type="hidden" name="xsrf" value="<%= secret %>"/>
        <div class="">
            <button autofocus type="submit" value="yes" name="logout" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                <%= __('auth.logout.yes') %>
            </button>
            <button type="submit" class="mt-4 w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
                <%= __('auth.logout.no') %>
            </button>
        </div>
    </form>
</div>