{
	"name": "c.authy",
	"version": "1.0.0",
	"main": "server.js",
	"type": "module",
	"scripts": {
		"compose:up": "docker compose up -d",
		"compose:down": "docker compose down",
		"development-launcher": "npm-run-all --parallel tailwind:watch start-launcher:debug",
		"development-server": "npm-run-all --parallel tailwind:watch start-server:debug",
		"build": "npm run tailwind:build",
		"production": "npm run start-launcher:production",
		"start-server:debug": "nodemon -r dotenv/config --inspect=0.0.0.0 src/server.js",
		"start-server:production": "node -r dotenv/config src/server.js",
		"start-launcher:debug": "nodemon -r dotenv/config --inspect=0.0.0.0 src/launcher.js",
		"start-launcher:production": "node -r dotenv/config src/launcher.js",
		"tailwind:build": "npx @tailwindcss/cli -i ./src/tailwind/input.css -o ./src/tailwind/dist/tailwind.css",
		"tailwind:watch": "npx @tailwindcss/cli -i ./src/tailwind/input.css -o ./src/tailwind/dist/tailwind.css --watch",
		"lint": "eslint .",
		"format": "prettier --write ."
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"description": "",
	"dependencies": {
		"@tailwindcss/cli": "^4.2.1",
		"argon2": "^0.43.0",
		"better-sqlite3-multiple-ciphers": "^11.8.0",
		"better-sqlite3-session-store": "^0.1.0",
		"cookie-parser": "^1.4.7",
		"cross-spawn": "^7.0.6",
		"csrf-csrf": "^3.1.0",
		"dotenv": "^16.4.5",
		"ejs": "^3.1.10",
		"email-validator": "^2.0.4",
		"encrypted-secret-launcher": "^1.0.0",
		"express": "^5.0.0",
		"express-ejs-layouts": "^2.5.1",
		"express-session": "^1.18.1",
		"express-validator": "^7.2.1",
		"fs": "^0.0.1-security",
		"i18n": "^0.15.1",
		"marked": "^15.0.7",
		"node-jose": "^2.2.0",
		"nodemailer": "^7.0.12",
		"oidc-provider": "^9.4.0",
		"path": "^0.12.7",
		"pino": "^9.6.0",
		"pino-pretty": "^13.0.0",
		"qrcode": "^1.5.4",
		"rate-limiter-flexible": "^7.1.1",
		"speakeasy": "^2.0.0",
		"tailwindcss": "^4.1.10",
		"zxcvbn": "^4.4.2"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"globals": "^17.4.0",
		"nodemon": "^3.1.7",
		"npm-run-all": "^4.1.5",
		"prettier": "^3.8.1"
	}
}
